{
  "cwd": "/path/to/workspace",
  "max_parallel": 3,
  "_meta": {
    "setup": {
      "install_scope": "isolated",
      "runners_dir": "/path/to/acp-subagent-orchestrator/.runtime/runners",
      "note": "仅 setup 阶段使用；runner 默认安装在 skill/.runtime/runners，且禁止自动全局安装。acp_orchestrator 运行期忽略该字段。"
    }
  },
  "agents": {
    "codex": {
      "command": ["/Users/you/.acp-subagent-orchestrator/runners/codex/node_modules/.bin/codex-acp"],
      "auto_approve_permissions": true,
      "default_config_options": {
        "mode": "full-access"
      },
      "strict_session_config": false
    },
    "claude": {
      "command": ["/Users/you/.acp-subagent-orchestrator/runners/claude/node_modules/.bin/claude-agent-acp"],
      "env": {
        "ANTHROPIC_API_KEY": "$ANTHROPIC_API_KEY"
      },
      "auto_approve_permissions": true,
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "strict_session_config": false
    },
    "copilot": {
      "command": ["/Users/you/.acp-subagent-orchestrator/runners/copilot/node_modules/.bin/copilot", "--acp", "--stdio"],
      "auto_approve_permissions": true,
      "strict_session_config": false
    }
  }
}
